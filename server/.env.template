# Security (REQUIRED)
SECRET_KEY=change-me-use-a-long-random-string

# Google OAuth Configuration (REQUIRED)
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Base domain - the domain of this server (REQUIRED for production)
# Used to derive SERVER_URL (as https://{BASE_DOMAIN}) and cookie domain
# Example: extrasuite.example.com
# BASE_DOMAIN=

# Server URL - base URL for this server (optional if BASE_DOMAIN is set)
# If not set, derived from BASE_DOMAIN as https://{BASE_DOMAIN}
# For local development, set explicitly to http://localhost:8001
SERVER_URL=http://localhost:8001

# Google Cloud Project for Service Account Creation and Firestore (REQUIRED)
# This is the project where service accounts will be created
# Firestore collections (users, oauth_states) are created automatically
GOOGLE_CLOUD_PROJECT=your-project-id

# Firestore database name (optional, defaults to "(default)")
# FIRESTORE_DATABASE=(default)
#
# Firestore TTL policies and composite indexes are created automatically at
# server startup. The server's service account needs 'roles/datastore.indexAdmin'
# for this to work. If that role is not granted, a warning is logged and you
# can create them manually — see server/src/extrasuite/server/firestore_setup.py
# for the full list of required indexes and TTL fields.

# Session Cookie Settings (all optional, secure defaults for production)
# SESSION_COOKIE_NAME=session
# SESSION_COOKIE_EXPIRY_MINUTES=1440  # 24 hours
# SESSION_COOKIE_SAME_SITE=lax        # Options: lax, strict, none
# SESSION_COOKIE_HTTPS_ONLY=true
# SESSION_COOKIE_DOMAIN=              # Defaults to BASE_DOMAIN if set

# Token Settings (optional)
# TOKEN_EXPIRY_MINUTES=60             # 1 hour (access token lifetime)

# Domain-Wide Delegation (optional)
# Enables /api/delegation/* endpoints for user-level API access (Gmail, Calendar, etc.)
# Requires domain-wide delegation configured in Google Workspace Admin Console.
# DELEGATION_ENABLED=true
#
# Optional scope allowlist (comma-separated short scope names).
# When set, only these scopes can be requested. When empty, any scope is allowed
# (Google Workspace Admin Console still enforces authorized scopes).
# DELEGATION_SCOPES=gmail.compose,gmail.readonly,calendar,contacts.readonly,contacts.other.readonly,script.projects,drive.file

# Session Token Settings (v2 auth protocol)
# SESSION_TOKEN_EXPIRY_DAYS=30         # How long session tokens stay valid (default 30 days)
# ADMIN_EMAILS=admin@example.com       # CSV of admin emails who can manage all sessions

# Performance Tuning (optional)
# THREAD_POOL_SIZE=10      # Max threads for blocking I/O (DWD signing, OAuth exchange, SA impersonation)
# RATE_LIMIT_AUTH=10/minute   # Rate limit for auth endpoints (/token/auth, /auth/callback, etc.)
# RATE_LIMIT_TOKEN=60/minute  # Rate limit for /auth/token (credential exchange)
# RATE_LIMIT_ADMIN=30/minute  # Rate limit for /admin/sessions endpoints

# Credential Mode (optional, default: sa+dwd)
# Controls how SA-class (sheet/doc/slide/form) and DWD-class (gmail/calendar/etc.) commands authenticate.
#
#   sa+dwd   (default): SA token for sheet/doc/slide/form; DWD token for gmail/calendar/etc.
#             Requires: Workspace admin to enable DWD.
#
#   sa+oauth: SA token for sheet/doc/slide/form; user OAuth token for gmail/calendar/etc.
#             Requires: OAUTH_SCOPES and OAUTH_TOKEN_ENCRYPTION_KEY. No DWD needed.
#
#   oauth:    User OAuth token for ALL commands (no agent attribution in Drive version history).
#             Requires: OAUTH_SCOPES and OAUTH_TOKEN_ENCRYPTION_KEY. No DWD or SA sharing needed.
#
# CREDENTIAL_MODE=sa+dwd

# OAuth Scopes (required when CREDENTIAL_MODE != sa+dwd)
# Comma-separated short scope names to request at consent time.
# Only the minimum scopes needed by your deployment — unused scopes are a security risk.
# OAUTH_SCOPES=spreadsheets,documents,presentations,forms.body,drive.readonly,gmail.compose,gmail.readonly,calendar,contacts.readonly,script.projects

# OAuth Token Encryption Key (required when CREDENTIAL_MODE != sa+dwd)
# AES-256-GCM key for encrypting refresh tokens stored in Firestore (32-byte hex string).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Production (strongly recommended): load from Cloud Run secret manager:
#   gcloud secrets create extrasuite-oauth-key --replication-policy=automatic
#   printf 'YOUR_32_BYTE_HEX_KEY' | gcloud secrets versions add extrasuite-oauth-key --data-file=-
# Then in Cloud Run deployment: --set-secrets OAUTH_TOKEN_ENCRYPTION_KEY=extrasuite-oauth-key:latest
# OAUTH_TOKEN_ENCRYPTION_KEY=
